#Player Similarity Finder
print("Player Similarity Finder")

con = True
eclid = np.array([])
top_match = np.array([])

while con:
    player_name = input("Enter a player's name or e to exit:")

    if player_name.lower() == 'e':
        con = False
        break

    if player_name not in data['Player Name'].values:
        print("Player not found. Please try again.")
        continue

    pos = input("Enter the position (GKP, DEF, MID, FWD): ").upper()

    if pos not in ['GKP', 'DEF', 'MID', 'FWD']:
        print("Invalid position. Please enter GKP, DEF, MID, or FWD.")
        continue

    if pos == 'GKP':
        p1 = np.array(top_goalkeepers[top_goalkeepers['Player Name'] == player_name][['Clean Sheets', 'Goals Conceded', 'Saves', 'Saves %', 'Penalties Saved', 'Punches', 'High Claims', 'Goals Prevented']])
        p2 = np.array(top_goalkeepers[['Clean Sheets', 'Goals Conceded', 'Saves', 'Saves %', 'Penalties Saved', 'Punches', 'High Claims', 'Goals Prevented']])
        eclid = np.sqrt(np.sum((p1 - p2) ** 2, axis=1))
        target_idx = np.where(top_goalkeepers['Player Name'] == player_name)
        eclid[target_idx] = np.inf  # Set their distance to themselves to Infinity
        top_match = np.argmin(eclid)
            
        print(top_goalkeepers.iloc[top_match]['Player Name'], "is the most similar player to", player_name)     

