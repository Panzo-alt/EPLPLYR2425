from pathlib import Path
import numpy as np 
import pandas as pd
import seaborn as sns
import matplotlib.pyplot as plt
import os

data = pd.read_csv("epl_player_stats_24_25.csv", delimiter=",")

dir = Path("reports")
dir.mkdir(parents=True, exist_ok=True)

#Descriptive Analytics & Traditional Leaderboards

#Finishing
fin_stats = data[['Player Name', 'Club', 'Goals', 'Shots', 'Shots On Target', 'Conversion %', 'Big Chances Missed', 'Hit Woodwork', 'Offsides']]
top_finishers = fin_stats[fin_stats.Goals > 10][['Player Name', 'Club', 'Goals', 'Shots', 'Shots On Target', 'Conversion %', 'Big Chances Missed', 'Hit Woodwork', 'Offsides']].sort_values(by='Goals', ascending=False)
top_finishers.to_csv(dir / "top_finishers.csv", index=False)

#Best Finisher
top_fin_per = top_finishers

top_fin_per['Goals_Percentile'] = top_finishers['Goals'].rank(pct=True) * 100
top_fin_per['Shots_Percentile'] = top_finishers['Shots'].rank(pct=True) * 100
top_fin_per['Shots_On_Target_Percentile'] = top_finishers['Shots On Target'].rank(pct=True) * 100
top_fin_per['Conversion_Percentile'] = top_finishers['Conversion %'].rank(pct=True) * 100

top_fin_per = top_fin_per.drop(columns=['Goals', 'Shots', 'Shots On Target', 'Conversion %', 'Big Chances Missed', 'Hit Woodwork', 'Offsides'])
top_fin_per['Attacking_Percentile'] = round((top_fin_per['Goals_Percentile'] + top_fin_per['Shots_Percentile'] + top_fin_per['Shots_On_Target_Percentile'] + top_fin_per['Conversion_Percentile']) / 4, 2)

top_fin_per = top_fin_per.sort_values(by='Attacking_Percentile', ascending=False)
top_fin_per.to_csv(dir / "top_finishers_percentiles.csv", index=False)

