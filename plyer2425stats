from pathlib import Path
import numpy as np 
import pandas as pd
import seaborn as sns
import matplotlib.pyplot as plt
import os

data = pd.read_csv("epl_player_stats_24_25.csv", delimiter=",")

dir = Path("reports")
dir.mkdir(parents=True, exist_ok=True)

#Descriptive Analytics & Traditional Leaderboards

#Finishing
fin_stats = data[['Player Name', 'Club', 'Goals', 'Shots', 'Shots On Target', 'Conversion %', 'Big Chances Missed', 'Hit Woodwork', 'Offsides']]
top_finishers = fin_stats[fin_stats.Goals > 10][['Player Name', 'Club', 'Goals', 'Shots', 'Shots On Target', 'Conversion %', 'Big Chances Missed', 'Hit Woodwork', 'Offsides']].sort_values(by='Goals', ascending=False)
top_finishers.to_csv(dir / "top_finishers.csv", index=False)

#Creativity
creativ_stats = data[['Player Name', 'Club', 'Assists', 'Touches', 'Passes', 'Passes%', 'Crosses', 'Crosses %', 'fThird Passes', 'fThird Passes %', 'Through Balls', 'Carries', 'Progressive Carries', 'Carries Ended with Goal', 'Carries Ended with Assist', 'Carries Ended with Shot', 'Carries Ended with Chance']]
top_creators = creativ_stats[creativ_stats.Assists > 5][['Player Name', 'Club', 'Assists', 'Touches', 'Passes', 'Passes%', 'Crosses', 'Crosses %', 'fThird Passes', 'fThird Passes %', 'Through Balls', 'Carries', 'Progressive Carries', 'Carries Ended with Goal', 'Carries Ended with Assist', 'Carries Ended with Shot', 'Carries Ended with Chance']].sort_values(by='Assists', ascending=False)
top_creators.to_csv(dir / "top_creators.csv", index=False)

#Defence
def_stats = data[['Player Name', 'Club', 'Clean Sheets', 'Possession Won', 'Clearances', 'Interceptions', 'Blocks', 'Tackles', 'Ground Duels', 'gDuels %', 'Aerial Duels', 'aDuels %', 'xGoT Conceded', 'Goals Conceded']]
top_defenders = data[data['Clean Sheets'] > 5][data['Position'] != 'GKP'][['Player Name', 'Club', 'Clean Sheets', 'Possession Won', 'Clearances', 'Interceptions', 'Blocks', 'Tackles', 'Ground Duels', 'gDuels %', 'Aerial Duels', 'aDuels %', 'xGoT Conceded', 'Goals Conceded']].sort_values(by='Clean Sheets', ascending=False)
top_defenders.to_csv(dir / "top_defenders.csv", index=False)

#Goalkeeper's Association
gk_stats = data[['Player Name', 'Club', 'Clean Sheets', 'Goals Conceded', 'Saves', 'Saves %', 'Penalties Saved', 'Punches', 'High Claims', 'Goals Prevented']]
top_goalkeepers = data[data['Position'] == 'GKP'][data['Clean Sheets'] > 5][['Player Name', 'Club', 'Clean Sheets', 'Goals Conceded', 'Saves', 'Saves %', 'Penalties Saved', 'Punches', 'High Claims', 'Goals Prevented']].sort_values(by='Clean Sheets', ascending=False)
top_goalkeepers.to_csv(dir / "top_goalkeepers.csv", index=False)